<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Leather Passport Holder - FalTrav</title>
  <link rel="stylesheet" href="../css/style.css">
  <style>
    .product-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    
    .product-header {
      margin-bottom: 30px;
      text-align: center;
    }
    
    .product-gallery {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 30px;
    }
    
    .main-image {
      flex: 1;
      min-width: 300px;
    }
    
    .main-image img {
      width: 100%;
      height: auto;
      border-radius: 8px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    .thumbnail-images {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      flex: 1;
      min-width: 200px;
    }
    
    .thumbnail-images img {
      width: 80px;
      height: 80px;
      object-fit: cover;
      border-radius: 4px;
      cursor: pointer;
      border: 2px solid transparent;
    }
    
    .thumbnail-images img:hover {
      border-color: #2c6fbb;
    }
    
    .product-details {
      margin-top: 30px;
    }
    
    .product-title {
      font-size: 2rem;
      margin-bottom: 10px;
      color: #2c3e50;
    }
    
    .product-price {
      font-size: 1.5rem;
      color: #27ae60;
      font-weight: bold;
      margin-bottom: 15px;
    }
    
    .product-description {
      margin-bottom: 20px;
      line-height: 1.6;
    }
    
    .product-type {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 4px;
      margin-bottom: 15px;
      font-weight: bold;
    }
    
    .digital {
      background-color: #e3f2fd;
      color: #1976d2;
    }
    
    .physical {
      background-color: #e8f5e9;
      color: #388e3c;
    }
    
    .purchase-btn {
      display: block;
      width: 100%;
      padding: 15px;
      background-color: #2c6fbb;
      color: white;
      border: none;
      border-radius: 4px;
      font-size: 1.2rem;
      cursor: pointer;
      margin-top: 20px;
      transition: background-color 0.3s;
    }
    
    .purchase-btn:hover {
      background-color: #1a4a8a;
    }
    
    .back-to-shop {
      display: inline-block;
      margin-bottom: 20px;
      color: #2c6fbb;
      text-decoration: none;
    }
    
    .back-to-shop:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header>
    <div class="container">
      <nav class="navbar">
        <div class="logo">
          <a href="../index.html">FalTrav</a>
        </div>
        <ul class="nav-links">
          <li><a href="../index.html">Home</a></li>
          <li><a href="../cities.html">Cities</a></li>
          <li><a href="../news.html">News</a></li>
          <li><a href="../shop.html">Shop</a></li>
          <li><a href="../games.html">Games</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main>
    <div class="product-page">
      <a href="../shop.html" class="back-to-shop">← Back to Shop</a>
      
      <div class="product-header">
        <h1 class="product-title">Leather Passport Holder</h1>
        <div class="product-type physical">Physical</div>
        <div class="product-price">$24.99</div>
      </div>
      
      <div class="product-gallery">
        <div class="main-image">
          <img src="https://picsum.photos/600/400?random=20" alt="Leather Passport Holder">
        </div>
        <div class="thumbnail-images">
          <img src="https://picsum.photos/100/100?random=40" alt="Passport Holder - Thumbnail 1">
          <img src="https://picsum.photos/100/100?random=41" alt="Passport Holder - Thumbnail 2">
          <img src="https://picsum.photos/100/100?random=42" alt="Passport Holder - Thumbnail 3">
          <img src="https://picsum.photos/100/100?random=43" alt="Passport Holder - Thumbnail 4">
        </div>
      </div>
      
      <div class="product-details">
        <h2>Description</h2>
        <p class="product-description">
          Protect your passport in style with our premium leather passport holder. Crafted from genuine top-grain 
          leather, this holder features a secure snap closure and multiple card slots to keep your travel documents 
          organized. The slim profile fits easily in any pocket or travel bag while providing protection from wear, 
          moisture, and accidental damage. Comes in classic brown leather with the option of personalization. 
          Makes an excellent gift for frequent travelers and those planning international adventures.
        </p>
        
        <h2>Features</h2>
        <ul>
          <li>Genuine top-grain leather construction</li>
          <li>Snap closure for secure protection</li>
          <li>Multiple card slots (holds 4-6 cards)</li>
          <li>Passport-sized interior</li>
          <li>RFID blocking technology</li>
          <li>Water-resistant coating</li>
          <li>Pen loop for convenience</li>
          <li>Personalization option available</li>
          <li>Available in brown or black</li>
        </ul>
        
        <button class="purchase-btn">Add to Cart - $24.99</button>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer>
    <div class="container">
      <div class="footer-content">
        <div class="footer-links">
          <a href="#">About Us</a>
          <a href="#">Contact</a>
          <a href="#">Privacy Policy</a>
        </div>
        <div class="copyright">
          © 2025 FalTrav. All rights reserved.
        </div>
      </div>
    </div>
  </footer>

  <script src="../js/translations.js"></script>
  <script src="../js/main.js"></script>
  <script>
    // Add to cart functionality
    document.querySelector('.purchase-btn').addEventListener('click', function() {
      alert('Leather Passport Holder added to cart!');
      // In a real implementation, this would add the item to a cart
    });
    
    // Image gallery functionality
    const mainImage = document.querySelector('.main-image img');
    const thumbnails = document.querySelectorAll('.thumbnail-images img');
    
    thumbnails.forEach(thumbnail => {
      thumbnail.addEventListener('click', function() {
        mainImage.src = this.src.replace('100/100', '600/400');
      });
    });
  </script>
</body>
</html>